public abstract class Hardware {
    private int id;
    private String brand;
    private String model;
    private int spec;
    private String type;
    
    public Hardware(int id, String brand, String model, int spec, String type) {
        this.id = id;
        this.brand = brand;
        this.model = model;
        this.spec = spec;
        this.type = type;
    }
    
    // Getters
    public int getId() { return id; }
    public String getBrand() { return brand; }
    public String getModel() { return model; }
    public int getSpec() { return spec; }
    public String getType() { return type; }
    
    // Abstract method to be overridden by subclasses
    public abstract String interpretSpec();
    
    @Override
    public String toString() {
        return String.format("%-3d | %-15s | %-15s | %-10s | %s", 
            id, brand, model, type, interpretSpec());
    }
}
