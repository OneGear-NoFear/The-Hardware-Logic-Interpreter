public class Laptop extends Hardware {
    
    public Laptop(int id, String brand, String model, int spec, String type) {
        super(id, brand, model, spec, type);
    }
    
    @Override
    public String interpretSpec() {
        int spec = getSpec();
        if (spec == 16) {
            return spec + "GB RAM";
        } else if (spec == 32) {
            return spec + "GB RAM";
        } else {
            return spec + "GB RAM"; // Default interpretation for laptops
        }
    }
}
